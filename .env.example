# Copy this file to .env for local development (never commit .env to git!)

# Generate a new secret key for production — never use the insecure default
SECRET_KEY=your-secret-key-here

# Set to True only in local development
DEBUG=True

# Comma-separated list of allowed hosts
# In Railway, set this to your Railway domain e.g.: myapp.up.railway.app
ALLOWED_HOSTS=localhost,127.0.0.1
